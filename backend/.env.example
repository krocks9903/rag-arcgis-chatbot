# Copy this file to .env in the backend directory and fill in your values
# Primary (fast): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Fallback: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: ArcGIS API key if you wire in a custom map layer
ARCGIS_API_KEY=your_arcgis_api_key_here

# Pipeline tuning (defaults shown)
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.1-8b-instant
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# SCORE_THRESHOLD=0.25
# SERVE_FRONTEND=true
# OTEL_ENABLED=false
