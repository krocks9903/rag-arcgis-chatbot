# Copy this file to .env and fill in your values
# Get a FREE token at: https://huggingface.co/settings/tokens

HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Your ArcGIS API key (free developer account at developers.arcgis.com)
ARCGIS_API_KEY=your_arcgis_api_key_here

# ArcGIS WebMap or Feature Layer URL to embed in the frontend
# Example: https://www.arcgis.com/home/webmap/viewer.html?webmap=YOUR_MAP_ID
ARCGIS_MAP_URL=https://www.arcgis.com/home/webmap/viewer.html?webmap=YOUR_MAP_ID
